{
  "name": "@easyqueue/desktop",
  "version": "1.4.0",
  "description": "Postman for Message Brokers — inspect, publish, and debug queue messages",
  "author": {
    "name": "Diego Sousa",
    "email": "diegointeriores11@gmail.com"
  },
  "repository": "github:sousadiego11/easyqueue",
  "private": true,
  "type": "module",
  "main": "dist/main/index.cjs",
  "scripts": {
    "dev:renderer": "vite",
    "build:main": "esbuild electron/main.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/main/index.cjs --external:electron",
    "build:preload": "esbuild electron/preload.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/main/preload.cjs --external:electron",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "dev:build": "npm run generate-icons && npm run build:main && npm run build:preload",
    "dev:electron": "wait-on tcp:5173 && cross-env NODE_ENV=development electron .",
    "dev": "npm run dev:build && concurrently -k -n \"renderer,electron\" -c \"cyan,magenta\" \"npm:dev:renderer\" \"npm:dev:electron\"",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "playwright test --headed --config e2e/playwright.config.ts",
    "generate-icons": "node scripts/generate-icons.mjs",
    "clean": "rm -rf dist .tsbuildinfo resources/icons resources/icon.png"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@easyqueue/core": "workspace:*",
    "@easyqueue/provider-rabbitmq": "workspace:*",
    "@easyqueue/provider-sqs": "workspace:*",
    "@easyqueue/shared": "workspace:*",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "postcss": "^8.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-resizable-panels": "^4.11.2",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vanilla-jsoneditor": "^3.12.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.3"
  }
}